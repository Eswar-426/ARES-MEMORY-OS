{
  "name": "ares-memory-vscode",
  "displayName": "ARES Memory OS",
  "description": "Zero-context-loss continuity for ARES Memory OS",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:aresMemorySidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ares.saveProjectMemory",
        "title": "ARES: Save Project Memory"
      },
      {
        "command": "ares.restoreProjectMemory",
        "title": "ARES: Restore Project Memory"
      },
      {
        "command": "ares.generateSnapshot",
        "title": "ARES: Generate Snapshot"
      },
      {
        "command": "ares.searchMemory",
        "title": "ARES: Search Memory"
      },
      {
        "command": "ares.projectStatus",
        "title": "ARES: Project Status"
      },
      {
        "command": "ares.copyContextToClipboard",
        "title": "ARES: Copy Context to Clipboard"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ares-memory",
          "title": "ARES Memory",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ares-memory": [
        {
          "type": "webview",
          "id": "aresMemorySidebar",
          "name": "Project Memory"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "16.x",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
