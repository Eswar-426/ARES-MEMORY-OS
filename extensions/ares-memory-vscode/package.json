{
  "name": "ares-memory-vscode",
  "displayName": "ARES Memory OS",
  "description": "Zero-context-loss continuity for ARES Memory OS",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "*"
  ],
  "contributes": {
    "commands": [
      {
        "command": "ares.doctor",
        "title": "ARES: Doctor"
      },
      {
        "command": "ares.ingest",
        "title": "ARES: Ingest Repository"
      },
      {
        "command": "ares.whyExists",
        "title": "ARES: Why Exists"
      },
      {
        "command": "ares.impactAnalysis",
        "title": "ARES: Impact Analysis"
      },
      {
        "command": "ares.coverageAnalysis",
        "title": "ARES: Coverage Analysis"
      },
      {
        "command": "ares.simulateChange",
        "title": "ARES: Simulate Change"
      },
      {
        "command": "ares.driftAnalysis",
        "title": "ARES: Drift Analysis"
      },
      {
        "command": "ares.traceabilityAnalysis",
        "title": "ARES: Traceability Analysis"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ares.whyExists",
          "group": "ares@1"
        },
        {
          "command": "ares.impactAnalysis",
          "group": "ares@2"
        },
        {
          "command": "ares.traceabilityAnalysis",
          "when": "explorerResourceIsFolder || explorerResourceIsFile",
          "group": "ares@4"
        },
        {
          "command": "ares.simulateChange",
          "when": "explorerResourceIsFolder || explorerResourceIsFile",
          "group": "ares@5"
        },
        {
          "command": "ares.driftAnalysis",
          "group": "ares@4"
        },
        {
          "command": "ares.traceabilityAnalysis",
          "group": "ares@5"
        }
      ],
      "explorer/context": [
        {
          "command": "ares.whyExists",
          "group": "ares@1"
        },
        {
          "command": "ares.impactAnalysis",
          "group": "ares@2"
        },
        {
          "command": "ares.driftAnalysis",
          "group": "ares@4"
        },
        {
          "command": "ares.traceabilityAnalysis",
          "when": "explorerResourceIsFolder || explorerResourceIsFile",
          "group": "ares@5"
        },
        {
          "command": "ares.simulateChange",
          "when": "explorerResourceIsFolder || explorerResourceIsFile",
          "group": "ares@6"
        }
      ]
    },
    "configuration": {
      "title": "ARES Memory OS",
      "properties": {
        "ares.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ares executable."
        },
        "ares.mcpPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ares-mcp executable."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "16.x",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1"
  }
}
